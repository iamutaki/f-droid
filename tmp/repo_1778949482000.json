lation\n- Daily, weekly, and monthly price change tracking\n- Currency conversion support\n\nUser Interface:\n- Clean and intuitive dashboard\n- Dark theme support\n- Home screen widget for quick price glance\n- Offline last-known price display\n"}, "icon": {"en-US": {"name": "/dev.cacing69.radar_emas/en-US/icon_cJS6r58Vl5TQQyiXdK638iRtthc84Y0X5Mze0ZpYqK0=.png", "sha256": "7094baaf9f159794d043289774aeb7f2246db6173ce18d17e4ccded19a58a8ad", "size": 112126}}, "preferredSigner": "251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad9007564a44"}, "versions": {"46e93874794b4e03b23e62334182b0aee83de321b6da5538a3701d2137b412ac": {"added": 1778949482000, "file": {"name": "/dev.cacing69.radar_emas-x86_64.apk", "sha256": "46e93874794b4e03b23e62334182b0aee83de321b6da5538a3701d2137b412ac", "size": 19414812}, "manifest": {"nativecode": ["x86_64"], "versionName": "0.1.1", "versionCode": 4101, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad9007564a44"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "dev.cacing69.radar_emas.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "c4129a51be3ec1752b72971bec2e57a3ea748480f99c84b36af7d609b51c8246": {"added": 1778949481000, "file": {"name": "/dev.cacing69.radar_emas-arm64-v8a.apk", "sha256": "c4129a51be3ec1752b72971bec2e57a3ea748480f99c84b36af7d609b51c8246", "size": 18053317}, "manifest": {"nativecode": ["arm64-v8a"], "versionName": "0.1.1", "versionCode": 2101, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad9007564a44"]}, "usesPermission": [{"name": "android.permission.INTERNET"}, {"name": "dev.cacing69.radar_emas.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"}]}}, "7c2ebb67d6b678424b1f7d4c838fd52fdcb0468f7d49496134bdf3734974ebd3": {"added": 1778949481000, "file": {"name": "/dev.cacing69.radar_emas-armeabi-v7a.apk", "sha256": "7c2ebb67d6b678424b1f7d4c8