hub.io/", "screenshots": {"phone": {"en-US": [{"name": "/dev.cacing69.radar_emas/en-US/phoneScreenshots/01.jpeg", "sha256": "5ea0f500ad4a02b2be57d40b9962235783431d6903f3a09c6f7d123a603b47f7", "size": 30712}, {"name": "/dev.cacing69.radar_emas/en-US/phoneScreenshots/02.jpeg", "sha256": "b5e94e2a6146d70c226aaa0f8cd3140a4a2a01105a9cf27f65d5fff952538401", "size": 23460}]}}, "name": {"en-US": "Radar Emas"}, "summary": {"en-US": "Free, open-source gold price tracker - monitor harga emas real-time"}, "description": {"en-US": "A free, open-source gold price tracker. Monitor real-time gold prices from multiple sources, set price alerts, and track market trends - all from your device. No accounts, no tracking.\n\nFeatures:\n\nPrice Tracking:\n- Real-time gold price updates from multiple sources\n- Support for various gold types (Antam, Logam Mulia, etc.)\n- Price history with charts and trend analysis\n- Multiple karat support (24K, 22K, 21K, 18K)\n\nAlerts & Notifications:\n- Customizable price alerts for buy/sell targets\n- Push notifications when price thresholds are reached\n- Price change percentage alerts\n\nMarket Data:\n- Buy and sell price display\n- Price spread calculation\n- Daily, weekly, and monthly price change tracking\n- Currency conversion support\n\nUser Interface:\n- Clean and intuitive dashboard\n- Dark theme support\n- Home screen widget for quick price glance\n- Offline last-known price display\n"}, "icon": {"en-US": {"name": "/dev.cacing69.radar_emas/en-US/icon_cJS6r58Vl5TQQyiXdK638iRtthc84Y0X5Mze0ZpYqK0=.png", "sha256": "7094baaf9f159794d043289774aeb7f2246db6173ce18d17e4ccded19a58a8ad", "size": 112126}}, "preferredSigner": "251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad9007564a44"}, "versions": {"86f38a0832175e055f693409dbaaf93d419b0f3d9371b5a8192a31ab438879d1": {"added": 1780951948000, "file": {"name": "/dev.cacing69.radar_emas-x86_64.apk", "sha256": "86f38a0832175e055f693409dbaaf93d419b0f3d9371b5a8192a31ab438879d1", "size": 20762420}, "manif