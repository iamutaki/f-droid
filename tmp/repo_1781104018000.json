mobile.staging/en-US/phoneScreenshots/01.jpeg", "sha256": "8956d138c9cb7fb8232473bfbb302a7fd26b7599ba17d6add6ce903fb9197a36", "size": 42316}, {"name": "/dev.iamutaki.jnn_mobile.staging/en-US/phoneScreenshots/02.jpeg", "sha256": "2e97100b44bf2450ccd4cac32aacaf337a258e9b6574de5276b0af43e3f0176b", "size": 172646}, {"name": "/dev.iamutaki.jnn_mobile.staging/en-US/phoneScreenshots/03.jpeg", "sha256": "7a61ca31799e5a182eb658d5d179e97ab798e50ca464b4e3045a0536b73e1d76", "size": 146510}]}}, "name": {"en-US": "JNN Mobile (Staging)"}, "summary": {"en-US": "WiFi service management app"}, "description": {"en-US": "A mobile app for managing WiFi/Internet services. Designed for field personnel and resellers to handle daily operations.\n\nFeatures:\n\nVoucher Management:\n- Send WiFi vouchers to customers\n- Track sent voucher status\n\nSales:\n- Record WiFi service sales transactions\n- Track sales history\n\nActivity Reports:\n- Create daily activity reports\n- Document field work\n\nMaster Data:\n- Manage subdistrict and village coverage area data\n- Manage WiFi service product data\n- Manage technical personnel data\n- Manage reseller data\n\nProfile:\n- Account info and profile settings\n"}, "icon": {"en-US": {"name": "/dev.iamutaki.jnn_mobile.staging/en-US/icon_wR2-A4yygyRj9RcOz5ENzV6nxX3QctH8wmpaZwVzN2I=.png", "sha256": "c11dbe038cb2832463f5170ecf910dcd5ea7c57dd072d1fcc26a5a6705733762", "size": 1020452}}, "preferredSigner": "251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad9007564a44"}, "versions": {"d48e0f530ecec26abd14dc8a79702db64861ae94a9955440343f3c46e9a359cc": {"added": 1780951948000, "file": {"name": "/dev.iamutaki.jnn_mobile.staging-x86_64.apk", "sha256": "d48e0f530ecec26abd14dc8a79702db64861ae94a9955440343f3c46e9a359cc", "size": 37622477}, "manifest": {"nativecode": ["x86_64"], "versionName": "0.0.10", "versionCode": 4010, "usesSdk": {"minSdkVersion": 24, "targetSdkVersion": 36}, "signer": {"sha256": ["251b142020e72938df647f22a373b93d9240ba3cbcd232f86772ad90075